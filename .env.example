# Copy this file to .env and fill in your values

# OpenAI API key
OPENAI_API_KEY=

# Optional: override the OpenAI model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Path to the XLSX template file
# TEMPLATE_PATH=templates/Finance_XLSX_Templates_new_new.xlsx

# Resend API key (https://resend.com)
RESEND_API_KEY=

# Email address to send results from (must be on a verified Resend domain)
EMAIL_FROM=finance@doveriye.com
