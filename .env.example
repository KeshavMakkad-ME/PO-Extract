# Copy this file to .env and fill in your values

# OpenAI API key
OPENAI_API_KEY=

# Optional: override the OpenAI model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Path to the XLSX template file (default: templates/Finance_XLSX_Templates_new_new.xlsx)
# TEMPLATE_PATH=templates/Finance_XLSX_Templates_new_new.xlsx

# SMTP settings for emailing results
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
