# Copy this file to .env and fill in your values

# OpenAI API key
OPENAI_API_KEY=

# Optional: override the OpenAI model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Path to the XLSX template file
# TEMPLATE_PATH=templates/Finance_XLSX_Templates_new_new.xlsx

# Google Apps Script mailer
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
MAILER_API_KEY=your-secret-key-here

# Always-CC list for results (comma-separated, optional)
# FINANCE_EMAILS=finance@btm.com,chandan@btm.com
